# Copy to .env.local for local development. Never commit the real value.

# Shared operator passphrase. Gates /operator (POST /api/auth) and every
# privileged backup/restore request (Authorization: Bearer <passphrase>).
# See docs/race-readiness-design.md "Auth model". In production this is set
# as a Vercel project env var.
PUBLISH_SECRET=

# Upstash Redis REST credentials (Vercel Marketplace KV store). Backs
# POST/GET /api/backup and GET /api/races. In production these are injected
# automatically and marked Sensitive, so `vercel env pull` can't fetch them —
# get plaintext values from console.upstash.com -> your database -> REST API
# section (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN; paste into
# these two, keeping these key names).
KV_REST_API_URL=
KV_REST_API_TOKEN=
